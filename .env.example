# =============================================================================
# Barmistvabrice — variables d'environnement
# Copier ce fichier en `.env.local` et remplir les valeurs.
# Tous les fichiers .env* sont ignorés par git (sauf ce .env.example).
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# URL publique de l'app (sert aux success_url / cancel_url Stripe).
# En local : http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
# Clé secrète (Mode test : commence par sk_test_... / Live : sk_live_...).
# Si absente, l'app tourne en "mode démo" (paiement simulé, sans Stripe).
STRIPE_SECRET_KEY="sk_test_..."

# Secret de signature du webhook checkout.session.completed.
# Local : fourni par `stripe listen` (commence par whsec_...).
# Prod  : copié depuis le endpoint webhook créé dans le dashboard.
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard (Project Settings > API)
# Si absent, l'app tourne en "mode démo" (données en mémoire).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Chaîne de connexion Postgres directe (Project Settings > Database).
# Utilisée uniquement par les scripts (`node scripts/run-migrations.mjs`).
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Resend — NOTIFICATION AGENCE uniquement (l'invité est confirmé par WhatsApp).
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Travel BA <onboarding@resend.dev>"
# Adresse de l'agence qui reçoit chaque nouvelle inscription / RSVP.
AGENCY_NOTIFY_EMAIL=""

# -----------------------------------------------------------------------------
# Twilio WhatsApp Business — CONFIRMATIONS INVITÉ (RSVP téphilines + voyage)
# https://console.twilio.com  (Account SID + Auth Token)
# Si absent, les confirmations WhatsApp sont ignorées (l'inscription reste OK).
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Numéro expéditeur WhatsApp approuvé, format "whatsapp:+<E164>".
# Sandbox de test Twilio : whatsapp:+14155238886
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Content SID (HX...) des templates WhatsApp approuvés par Meta, un par
# type de message et par langue. À créer dans Twilio Content Template Builder,
# puis coller le SID renvoyé après approbation.
#   BOOKING  : confirmation voyage    — variables {{1}}..{{6}}
#     {{1}} nom groupe, {{2}} enfant, {{3}} ref, {{4}} hôtel, {{5}} total, {{6}} lien PDF
#     Texte suggéré (FR, après les variables dynamiques) :
#     « L'équipe Travel Booking Agency se tient à votre disposition pour vous
#     accompagner dans les différentes étapes du voyage. Vous pouvez nous contacter
#     directement sur cette conversation WhatsApp ou joindre Raphael Zerdoun au
#     06 26 07 76 61. »
#   RSVP_YES : présence confirmée     — variables {{1}}..{{6}}
#   RSVP_NO  : réponse "absent"        — variables {{1}}, {{2}}
#   BOOKING_RELAUNCH : relance paiement (admin) — variables {{1}}..{{4}}
#     {{1}} nom groupe, {{2}} hôtel, {{3}} total, {{4}} lien Stripe Checkout
#     Texte suggéré (FR) :
#     « Bonjour {{1}}, votre réservation est en attente de paiement.
#     Hôtel : {{2}} — Total : {{3}}. Finalisez ici : {{4}}
#     L'équipe Travel Booking Agency reste à votre disposition sur cette
#     conversation WhatsApp ou au 06 26 07 76 61 (Raphael Zerdoun). »
TWILIO_WA_TEMPLATE_BOOKING_CONFIRMATION_FR=""
TWILIO_WA_TEMPLATE_BOOKING_CONFIRMATION_HE=""
TWILIO_WA_TEMPLATE_BOOKING_RELAUNCH_FR=""
TWILIO_WA_TEMPLATE_BOOKING_RELAUNCH_HE=""
# Templates "media" (document) : envoient le carnet de voyage PDF en piece
# jointe apres la confirmation. Facultatifs — sans eux, seul le lien est envoye.
TWILIO_WA_TEMPLATE_BOOKING_DOCS_FR=""
TWILIO_WA_TEMPLATE_BOOKING_DOCS_HE=""
TWILIO_WA_TEMPLATE_RSVP_YES_FR=""
TWILIO_WA_TEMPLATE_RSVP_YES_HE=""
TWILIO_WA_TEMPLATE_RSVP_NO_FR=""
TWILIO_WA_TEMPLATE_RSVP_NO_HE=""

# Rappels automatiques J-7 / J-1 (cron Vercel — voir vercel.json)
#   REMINDER_GLOBAL_J7   : 7 j. avant cérémonie, 10h Paris — {{1}} nom, {{2}} enfant, {{3}} détails
#   REMINDER_CEREMONY_J1 : veille cérémonie, 18h Paris  — {{1}}, {{2}}, {{3}} lieu/heure
#   REMINDER_TRIP_J1     : veille départ, 18h Paris    — {{1}}, {{2}}, {{3}} vol/hôtel, {{4}} lien PDF
# Corps suggéré REMINDER_GLOBAL_J7 (FR) :
#   Bonjour {{1}}, J-7 avant la Bar Mitsvah de {{2}} ! {{3}}
#   Travel Booking Agency · Raphael Zerdoun · 06 26 07 76 61
# Corps suggéré REMINDER_CEREMONY_J1 (FR) :
#   Bonjour {{1}}, rappel pour demain — Bar Mitsvah de {{2}} : {{3}}
# Corps suggéré REMINDER_TRIP_J1 (FR) :
#   Bonjour {{1}}, c'est demain le départ pour Mykonos ({{2}}) ! {{3}} Carnet : {{4}}
TWILIO_WA_TEMPLATE_REMINDER_GLOBAL_J7_FR=""
TWILIO_WA_TEMPLATE_REMINDER_GLOBAL_J7_HE=""
TWILIO_WA_TEMPLATE_REMINDER_CEREMONY_J1_FR=""
TWILIO_WA_TEMPLATE_REMINDER_CEREMONY_J1_HE=""
TWILIO_WA_TEMPLATE_REMINDER_TRIP_J1_FR=""
TWILIO_WA_TEMPLATE_REMINDER_TRIP_J1_HE=""

# Secret pour /api/cron/reminders (Vercel l'envoie en Authorization: Bearer …)
CRON_SECRET=""

# -----------------------------------------------------------------------------
# Google Sheets (export des réservations) — compte de service Google
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_SHEET_ID=""

# -----------------------------------------------------------------------------
# Espace admin
# À CHANGER EN PRODUCTION (valeurs par défaut connues publiquement).
# -----------------------------------------------------------------------------
# Mot de passe admin fixe dans le code (src/lib/admin-auth.ts) : 2026
# ADMIN_SECRET reste configurable pour invalider les sessions existantes.
ADMIN_SECRET="bmsb-secret"

# Secret de signature des liens PDF /api/documents (optionnel : ADMIN_SECRET
# est utilisé par défaut). Changer ce secret invalide les liens déjà envoyés.
DOCS_TOKEN_SECRET=""
